@API_HostAddress = http://localhost:5113

### Create workspace (success)
POST {{API_HostAddress}}/api/v1/workspaces
Content-Type: application/json

{
  "name": "Admin Console",
  "description": "Primary workspace for admin operations."
}

### Create workspace (duplicate)
POST {{API_HostAddress}}/api/v1/workspaces
Content-Type: application/json

{
  "name": "Admin Console",
  "description": "Duplicate name should fail."
}

### Create workspace (invalid)
POST {{API_HostAddress}}/api/v1/workspaces
Content-Type: application/json

{
  "name": " ",
  "description": "Invalid name should return 400."
}
